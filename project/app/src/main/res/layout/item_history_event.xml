<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardEvent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:cardPreventCornerOverlap="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- ── Accent gauche — couleur variable ──────────── -->
        <!-- rouge #C0392B si AUTO                           -->
        <!-- bleu #2E86C1 si MANUAL                         -->
        <!-- Défini programmatiquement dans l'Adapter       -->
        <View
            android:id="@+id/viewAccent"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#C0392B"/>

        <!-- ── Contenu de la card ─────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Ligne 1 — Icône + Titre + Badge ─────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:lineHeight="14sp"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <!-- Badge statut — fond et texte définis    -->
                <!-- programmatiquement dans l'Adapter       -->
                <TextView
                    android:id="@+id/tvBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="5dp"/>

            </LinearLayout>

            <!-- Ligne 2 — Date ──────────────────────────── -->
            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="#7F8C8D"
                android:layout_marginBottom="4dp"/>

            <!-- Ligne 3 — Contacts + GPS ────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvContacts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textStyle="bold"/>

                <View
                    android:layout_width="6dp"
                    android:layout_height="1dp"/>

                <TextView
                    android:id="@+id/tvGpsStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"/>

            </LinearLayout>

            <!-- Ligne 4 — Lien Maps ─────────────────────── -->
            <!-- Visible SEULEMENT si latitude != null       -->
            <TextView
                android:id="@+id/tvMapsLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="8sp"
                android:textColor="#95A5A6"
                android:layout_marginTop="3dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>