<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header rouge -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/red_primary"
        android:padding="16dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_permission_title"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Indicateur d'étapes -->
    <LinearLayout
        android:id="@+id/stepIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/step1"
            android:layout_width="28dp"
            android:layout_height="4dp"
            android:background="@color/red_primary"
            android:layout_marginEnd="4dp"/>

        <View
            android:id="@+id/step2"
            android:layout_width="20dp"
            android:layout_height="4dp"
            android:background="@color/border"
            android:layout_marginEnd="4dp"/>

        <View
            android:id="@+id/step3"
            android:layout_width="20dp"
            android:layout_height="4dp"
            android:background="@color/border"/>

    </LinearLayout>

    <!-- Contenu scrollable -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/stepIndicator"
        app:layout_constraintBottom_toTopOf="@id/btnAction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Card permission -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPermission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Icône + nom + badge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <!-- Icône -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardCornerRadius="18dp"
                            app:cardBackgroundColor="@color/red_surface"
                            app:cardElevation="0dp"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:id="@+id/tvPermIcon"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="@string/onboarding_icon_gps"
                                android:gravity="center"
                                android:textSize="16sp"/>

                        </androidx.cardview.widget.CardView>

                        <!-- Nom permission -->
                        <TextView
                            android:id="@+id/tvPermName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/onboarding_gps_name"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"/>

                        <!-- Badge requis -->
                        <TextView
                            android:id="@+id/tvPermBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/onboarding_required"
                            android:textColor="@color/red_primary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:background="@color/red_surface"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"/>

                    </LinearLayout>

                    <!-- Explication -->
                    <TextView
                        android:id="@+id/tvPermWhy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_gps_why"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Note -->
            <TextView
                android:id="@+id/tvNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_note_required"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:gravity="center"/>

        </LinearLayout>

    </ScrollView>

    <!-- Bouton action -->
    <Button
        android:id="@+id/btnAction"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:text="@string/onboarding_btn_allow"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:backgroundTint="@color/red_primary"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>