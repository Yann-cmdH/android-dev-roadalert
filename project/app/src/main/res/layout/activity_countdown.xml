<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#7B0000"
    android:keepScreenOn="true">

    <!-- ══ ÉTAT 1 — Countdown actif ══════════════════════════ -->

    <TextView
        android:id="@+id/tvCountdownTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/countdown_title"
        android:textColor="#DDFFFFFF"
        android:textSize="14sp"
        android:layout_marginTop="56dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <FrameLayout
        android:id="@+id/countdownContainer"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/tvCountdownTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.roadalert.cameroun.ui.countdown.CountdownRingView
            android:id="@+id/countdownRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvCountdownNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15"
                android:textColor="#FFFFFF"
                android:textSize="72sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvCountdownUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/countdown_seconds"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"/>

        </LinearLayout>

    </FrameLayout>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/countdown_subtitle"
        android:textColor="#AAFFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/countdownContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══ ÉTAT 2 — Annulé — caché initialement ══════════════ -->

    <TextView
        android:id="@+id/tvCancelledTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/countdown_cancelled_title"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvCancelledSub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvCancelledSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/countdown_cancelled_sub"
        android:textColor="#AAFFFFFF"
        android:textSize="13sp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvCancelledTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══ ÉTAT 3 — Expiré — caché initialement ══════════════ -->

    <TextView
        android:id="@+id/tvExpiredTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/countdown_expired_title"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvExpiredSub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvExpiredSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/countdown_expired_sub"
        android:textColor="#AAFFFFFF"
        android:textSize="13sp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvExpiredTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══ Bouton Annuler — ancré en bas ══════════════════════ -->

    <Button
        android:id="@+id/btnCancel"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="48dp"
        android:text="@string/countdown_btn_cancel"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#27AE60"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>